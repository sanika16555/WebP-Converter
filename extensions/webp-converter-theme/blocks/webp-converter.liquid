{{ 'webp-converter.css' | asset_url | stylesheet_tag }}

<div class="wc-wrapper" id="webp-converter-app">

  <div class="wc-hero">
    <div class="wc-hero__inner">
      <div class="wc-hero__badge">⚡ Free Tool</div>
      <h2 class="wc-hero__title">WebP Image Converter</h2>
      <p class="wc-hero__subtitle">
        Convert JPG &amp; PNG images to WebP format instantly.
        Up to 80% smaller file size — same visual quality.
      </p>
      <div class="wc-hero__formats">
        <span class="wc-format wc-format--from">JPG</span>
        <span class="wc-format wc-format--from">PNG</span>
        <span class="wc-format-arrow">→</span>
        <span class="wc-format wc-format--to">WebP</span>
      </div>
    </div>
  </div>

  <div class="wc-container">

    {%- comment -%} Drop Zone {%- endcomment -%}
    <div class="wc-card wc-card--upload">
      <div
        class="wc-dropzone"
        id="wc-dropzone"
        role="button"
        tabindex="0"
        aria-label="Drop images here or click to browse"
      >
        <div class="wc-dropzone__icon">🖼️</div>
        <p class="wc-dropzone__title">Drop your images here</p>
        <p class="wc-dropzone__sub">Supports JPG, JPEG &amp; PNG — multiple files at once</p>
        <div class="wc-dropzone__formats">
          <span class="wc-chip">image/jpeg</span>
          <span class="wc-chip">image/png</span>
        </div>
        <button class="wc-btn wc-btn--primary" id="wc-browse-btn" type="button">
          📁 Browse Files
        </button>
      </div>
      <input
        type="file"
        id="wc-file-input"
        accept=".jpg,.jpeg,.png,image/jpeg,image/png"
        multiple
        hidden
        aria-label="Select image files"
      >
    </div>

    {%- comment -%} Toolbar — shown only when files are loaded {%- endcomment -%}
    <div class="wc-toolbar" id="wc-toolbar" hidden>
      <span class="wc-toolbar__count">
        <strong id="wc-count-total">0</strong> images loaded &nbsp;·&nbsp;
        <strong id="wc-count-done">0</strong> converted
      </span>
      <div class="wc-toolbar__actions">
        <button class="wc-btn wc-btn--ghost" id="wc-clear-btn" type="button">🗑 Clear All</button>
        <button class="wc-btn wc-btn--success" id="wc-dl-all-btn" type="button" hidden>⬇ Download All</button>
        <button class="wc-btn wc-btn--primary" id="wc-convert-btn" type="button">⚡ Convert to WebP</button>
      </div>
    </div>

    {%- comment -%} Stats — shown after conversions complete {%- endcomment -%}
    <div class="wc-stats" id="wc-stats" hidden>
      <div class="wc-stat-card">
        <div class="wc-stat-card__value wc-stat-card__value--purple" id="wc-stat-count">0</div>
        <div class="wc-stat-card__label">Converted</div>
      </div>
      <div class="wc-stat-card">
        <div class="wc-stat-card__value" id="wc-stat-orig">0 KB</div>
        <div class="wc-stat-card__label">Original Size</div>
      </div>
      <div class="wc-stat-card">
        <div class="wc-stat-card__value wc-stat-card__value--green" id="wc-stat-saved">0%</div>
        <div class="wc-stat-card__label">Space Saved</div>
      </div>
    </div>

    {%- comment -%} File List {%- endcomment -%}
    <div class="wc-file-list" id="wc-file-list">
      <div class="wc-empty" id="wc-empty">
        <span class="wc-empty__icon">📂</span>
        <p>No images loaded yet. Drop some files above to get started.</p>
      </div>
    </div>

  </div>
</div>

<script src="{{ 'webp-converter.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "WebP Converter",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WebP Image Converter"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Convert JPG & PNG images to WebP — up to 80% smaller, same quality."
    }
  ]
}
{% endschema %}
